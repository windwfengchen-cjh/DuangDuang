#!/bin/bash
# 图片识别快捷脚本
# 用法: ./img <图片路径> [提示词]

IMAGE_PATH="$1"
PROMPT="${2:-描述这张图片的内容}"

if [ -z "$IMAGE_PATH" ]; then
    echo "用法: ./img <图片路径> [提示词]"
    echo "示例: ./img /path/to/image.png"
    echo "示例: ./img /path/to/image.png '提取图片中的文字'"
    exit 1
fi

# 检查 API Key
if [ -z "$GEMINI_API_KEY" ] && [ -z "$KIMI_API_KEY" ]; then
    echo "错误：请设置 GEMINI_API_KEY 或 KIMI_API_KEY 环境变量"
    echo "获取 Gemini API Key: https://aistudio.google.com/app/apikey"
    exit 1
fi

# 默认使用 Gemini
PROVIDER="${PROVIDER:-gemini}"

python3 /home/admin/openclaw/workspace/image_analyze.py "$IMAGE_PATH" "$PROVIDER" "$PROMPT"
