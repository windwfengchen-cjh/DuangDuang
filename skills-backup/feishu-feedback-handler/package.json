{
  "name": "feishu-feedback-handler",
  "version": "1.3.0",
  "description": "飞书跨群问题反馈处理系统 - 支持多群配置、消息自动转发、表格自动记录、状态自动更新、直接调用需求跟进流程",
  "main": "src/index.ts",
  "author": "DuangDuang",
  "maintainer": "陈俊洪",
  "license": "MIT",
  "keywords": [
    "feishu",
    "lark",
    "feedback",
    "bitable",
    "forward",
    "automation"
  ],
  "categories": [
    "productivity",
    "automation",
    "integration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/feishu-feedback-handler"
  },
  "engines": {
    "openclaw": ">=0.5.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0"
  },
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "bitable": {
          "type": "object",
          "properties": {
            "app_token": {
              "type": "string",
              "description": "飞书多维表格 App Token"
            },
            "table_id": {
              "type": "string",
              "description": "表格 ID"
            }
          },
          "required": [
            "app_token",
            "table_id"
          ]
        },
        "bot": {
          "type": "object",
          "properties": {
            "bot_id": {
              "type": "string",
              "description": "机器人 Open ID"
            }
          },
          "required": [
            "bot_id"
          ]
        },
        "forward_configs": {
          "type": "object",
          "description": "转发配置映射表，key为来源群chat_id",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "target_chat_id": {
                "type": "string",
                "description": "目标群chat_id"
              },
              "handlers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "user_id": {
                      "type": "string"
                    },
                    "user_name": {
                      "type": "string"
                    }
                  }
                }
              },
              "source_name": {
                "type": "string",
                "description": "来源群显示名称"
              },
              "record_bitable": {
                "type": "boolean",
                "default": true,
                "description": "是否记录到表格"
              },
              "notify_boss_for_requirement": {
                "type": "boolean",
                "default": true,
                "description": "需求类是否额外@Boss"
              }
            },
            "required": [
              "target_chat_id",
              "handlers",
              "source_name"
            ]
          }
        },
        "boss": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string"
            },
            "user_name": {
              "type": "string"
            }
          },
          "description": "Boss信息，需求类消息会@Boss"
        }
      },
      "required": [
        "bitable",
        "bot",
        "forward_configs"
      ]
    },
