{
  "id": "feishu-feedback-handler",
  "name": "飞书反馈处理",
  "version": "1.0.0",
  "description": "飞书跨群问题反馈自动处理系统",
  "entry": "src/index.ts",
  "commands": [
    {
      "name": "init",
      "description": "初始化配置，创建必要的配置文件"
    },
    {
      "name": "test-forward",
      "description": "测试转发功能"
    },
    {
      "name": "sync-contacts",
      "description": "同步群成员到联系人映射表"
    },
    {
      "name": "config",
      "description": "查看当前配置"
    },
    {
      "name": "validate",
      "description": "验证配置是否正确"
    },
    {
      "name": "forward",
      "description": "手动执行转发",
      "args": [
        {
          "name": "source_chat_id",
          "required": true,
          "description": "来源群chat_id"
        },
        {
          "name": "content",
          "required": true,
          "description": "消息内容"
        }
      ]
    },
    {
      "name": "update-status",
      "description": "手动更新问题状态",
      "args": [
        {
          "name": "keywords",
          "required": true,
          "description": "问题关键词"
        },
        {
          "name": "status",
          "required": true,
          "description": "新状态"
        }
      ]
    }
  ],
  "hooks": {
    "onMessage": {
      "handler": "handleMessage",
      "description": "处理飞书消息事件"
    },
    "onMention": {
      "handler": "handleMention",
      "description": "处理被@的消息"
    }
  },
  "permissions": [
    "feishu:messages:send",
    "feishu:messages:read",
    "feishu:groups:read",
    "feishu:bitable:read",
    "feishu:bitable:write",
    "feishu:contacts:read"
  ],
  "config": {
    "file": "config.json",
    "schema": "package.json#/config/schema"
  }
}